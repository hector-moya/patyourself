# PatYourSelf — production environment template (Laravel Forge).
# Copy these into the site's "Environment" tab in Forge and fill the blanks.
# Forge auto-populates APP_KEY and the DB_* credentials when it creates the site;
# everything else you set by hand. NEVER commit a filled-in copy of this file.

APP_NAME=PatYourSelf
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Surface the app name to the Vite/Inertia build.
VITE_APP_NAME="${APP_NAME}"

# Hashing
BCRYPT_ROUNDS=12

# Logging — keep production quiet; errors only.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# Database — Forge fills these in when it provisions the MySQL database.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sessions / cache / queue all ride the database (no Redis to manage on a small
# VPS). The jobs, sessions and cache tables ship in the default migrations.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# Filesystem
FILESYSTEM_DISK=local

# Mail — set to your provider; `log` is a safe default until SMTP is wired.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Coach (LLM) ───────────────────────────────────────────────────────────────
# All LLM calls are server-side. The API key never leaves the backend.
# Provider credentials are read by config/ai.php (laravel/ai package).
# Model is set per-agent via #[Model] attributes; no global override needed.
ANTHROPIC_API_KEY=

# Cost guard: rolling-24h per-user token budget (0 disables). Over budget -> 429.
COACH_DAILY_TOKEN_BUDGET=200000
# Rate limit: coach requests per user per minute (0 disables).
COACH_RATE_PER_MINUTE=20
